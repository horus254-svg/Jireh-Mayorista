function generarPDFPedido(
  pedidoId,
  fecha,
  data
){

  // La carpeta es configurable desde Configuración → Imágenes de
  // productos (clave DRIVE_CARPETA_PEDIDOS_ID). Si nunca se tocó esa
  // configuración, leerClaveConfiguracion devuelve el ID original que
  // siempre usó el sistema, así que esto nunca rompe instalaciones
  // existentes por no haber configurado nada todavía.
  const carpetaId = extraerIdCarpetaDrive(
    leerClaveConfiguracion("DRIVE_CARPETA_PEDIDOS_ID", "1T4k00L3LIIyq0jId0A5mf6YOAWYngWmo")
